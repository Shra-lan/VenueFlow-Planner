rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // Primitive Helpers
    function isSignedIn() {
      return request.auth != null;
    }

    function isVerifiedUser() {
      return isSignedIn() && request.auth.token.email_verified == true;
    }

    function isAdmin() {
      return isSignedIn() && request.auth.token.email == 'trshraddha6@gmail.com';
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    // Entity Validations
    function isValidAlert(data) {
      return data.keys().hasAll(['id', 'type', 'status', 'userId', 'createdAt']) &&
             data.keys().size() >= 5 && data.keys().size() <= 9 &&
             data.id is string && data.id.size() <= 128 &&
             data.type in ['Medical', 'Security'] &&
             data.status in ['Active', 'Resolved'] &&
             data.userId == request.auth.uid &&
             data.createdAt is timestamp &&
             data.get('stand', '') is string && data.get('stand', '').size() <= 128 &&
             data.get('row', '') is string && data.get('row', '').size() <= 64 &&
             data.get('seat', '') is string && data.get('seat', '').size() <= 64 &&
             data.get('eta', '') is string && data.get('eta', '').size() <= 64;
    }

    match /alerts/{alertId} {
      allow get: if isVerifiedUser() && (isValidId(alertId)) && (existing().userId == request.auth.uid || isAdmin());
      allow list: if isVerifiedUser() && (resource.data.userId == request.auth.uid || isAdmin());
      
      allow create: if isVerifiedUser() && isValidId(alertId) && isValidAlert(incoming()) && incoming().createdAt == request.time;
      
      allow update: if isVerifiedUser() && isValidId(alertId) && (
        isAdmin() || 
        (
          existing().userId == request.auth.uid && 
          existing().status != 'Resolved' &&
          isValidAlert(incoming()) &&
          incoming().diff(existing()).affectedKeys().hasOnly(['status', 'eta']) &&
          incoming().userId == existing().userId &&
          incoming().createdAt == existing().createdAt
        )
      );

      allow delete: if isAdmin() && isValidId(alertId);
    }
  }
}
