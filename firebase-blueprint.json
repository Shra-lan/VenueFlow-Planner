{
  "entities": {
    "Gate": {
      "title": "Gate",
      "description": "Represents a stadium gate and its current wait time.",
      "type": "object",
      "properties": {
        "name": {
          "type": "string",
          "description": "The name of the gate (e.g., Gate N)"
        },
        "waitTime": {
          "type": "number",
          "description": "Current wait time in minutes"
        },
        "status": {
          "type": "string",
          "enum": ["normal", "busy", "closed"],
          "description": "Current status of the gate"
        }
      },
      "required": ["name", "waitTime", "status"]
    },
    "Alert": {
      "title": "Alert",
      "description": "Represents a global broadcast alert for attendees.",
      "type": "object",
      "properties": {
        "message": {
          "type": "string",
          "description": "The alert message content"
        },
        "type": {
          "type": "string",
          "enum": ["info", "warning", "critical"],
          "description": "The severity level of the alert"
        },
        "time": {
          "type": "string",
          "description": "Formatted time string for display"
        },
        "createdAt": {
          "type": "timestamp",
          "description": "When the alert was created"
        }
      },
      "required": ["message", "type", "time", "createdAt"]
    }
  },
  "firestore": {
    "/gates/{gateId}": {
      "schema": {
        "$ref": "#/entities/Gate"
      },
      "description": "Collection of stadium gates"
    },
    "/alerts/{alertId}": {
      "schema": {
        "$ref": "#/entities/Alert"
      },
      "description": "Collection of active alerts"
    }
  }
}
